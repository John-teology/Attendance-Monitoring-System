<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sky_gradient"
    tools:context=".ui.MainActivity">

    <ImageView
        android:id="@+id/ivAppBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.8"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_book"
            android:scaleType="fitCenter"/>

        <TextView
            android:id="@+id/tvSchoolName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Library Attendance"
            android:textColor="#111827"
            android:textSize="44sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textAlignment="center"
            android:clickable="true"
            android:focusable="false"
            tools:text="Library Attendance"
            tools:visibility="visible"/>
    </LinearLayout>

    <!-- Toggle Buttons -->
    <LinearLayout
        android:id="@+id/toggleContainer"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:weightSum="2"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_constraintTop_toBottomOf="@+id/headerContent">

        <!-- QR Button -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnModeQr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_toggle_qr"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconQr"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_qr_code"
                app:tint="#111827"
                app:layout_constraintBottom_toTopOf="@+id/textQr"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/textQr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="QR CODE"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iconQr" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- NFC Button -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnModeNfc"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_toggle_nfc"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconNfc"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_nfc"
                app:tint="#059669"
                app:layout_constraintBottom_toTopOf="@+id/textNfc"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/textNfc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="NFC ID SCANNING"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:shadowColor="#40000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iconNfc" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- Main Content Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/mainCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="-20dp"
        app:cardBackgroundColor="#CCFFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toggleContainer">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <!-- Card Header -->
            <TextView
                android:id="@+id/tvStatusHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#374151"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Scanner Graphic Area -->
            <FrameLayout
                android:id="@+id/scanGraphicContainer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginBottom="24dp"
                app:layout_constraintBottom_toTopOf="@+id/statsBox"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvStatusHeader">

                <!-- Wave/Ripple Views -->
                <View
                    android:id="@+id/wave1"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_button"
                    android:backgroundTint="#DBEAFE"
                    android:alpha="0" />

                <View
                    android:id="@+id/wave2"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_button"
                    android:backgroundTint="#BFDBFE"
                    android:alpha="0" />

                <View
                    android:id="@+id/wave3"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_button"
                    android:backgroundTint="#93C5FD"
                    android:alpha="0" />

                <!-- Central Icon (Changes based on mode) -->
                <ImageView
                    android:id="@+id/ivCenterIcon"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_scanner_device"
                    app:tint="#2563EB" />
                    
                <!-- Status Text centered at bottom of this block -->
                <TextView
                    android:id="@+id/tvStatusFooter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="24dp"
                    android:text="Scanning Standby..."
                    android:textColor="#111827"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Hidden legacy views if referenced in code but unused -->
                <View
                    android:id="@+id/qrScanArea"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"/>
                    
                <View
                    android:id="@+id/nfcScanArea"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"/>
                    
                 <View
                    android:id="@+id/scanLine"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#EF4444"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Stats Box -->
            <LinearLayout
                android:id="@+id/statsBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_stats_container"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:paddingVertical="12dp"
                android:weightSum="2"
                app:layout_constraintBottom_toTopOf="@+id/tvDateTime">

                <!-- Active Count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="4dp"
                            android:src="@drawable/ic_user"
                            app:tint="#2563EB" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Count"
                            android:textColor="#374151"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTodayCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="#065F46"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+0 Today"
                        android:textColor="#10B981"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#E5E7EB" />

                <!-- On Going -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="4dp"
                            android:src="@drawable/ic_clock_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="On Going"
                            android:textColor="#374151"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSyncedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="#064E3B"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- Footer Date Time -->
            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:text="Tuesday, April 23, 2024 • 9:41 AM"
                android:textColor="#6B7280"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Contact Footer (Shown only when default title is used) -->
            <TextView
                android:id="@+id/tvContactFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact: sales.techyitsolutions@gmail.com"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Hidden Views needed for Code logic -->
            <View
                 android:id="@+id/dashedFrame"
                 android:layout_width="0dp"
                 android:layout_height="0dp"
                 android:visibility="gone"
                 app:layout_constraintTop_toTopOf="parent"
                 app:layout_constraintStart_toStartOf="parent"/>
                 
            <TextView
                 android:id="@+id/tvSyncStatus"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:visibility="gone"
                 app:layout_constraintTop_toTopOf="parent"
                 app:layout_constraintStart_toStartOf="parent"/>
                 
             <TextView
                 android:id="@+id/tvPendingCount"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:visibility="gone"
                 app:layout_constraintTop_toTopOf="parent"
                 app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>